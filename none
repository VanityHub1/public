    end
    function win:SetWatermarkSuffix(s)
        win._wmSuffix = s or ""
    end

    return win
end

function Window:_ClosePopups(ignore)
    local i = 1
    while i <= #self._openPopups do
        local popup = self._openPopups[i]
        if popup ~= ignore then
            if popup._type == "dropdown" then
                if popup._popup then popup._popup.Visible = false elseif popup._optionsHolder then popup._optionsHolder.Visible = false end
                popup._indicator.Text = "▼"
                popup._open = false
            elseif popup._type == "multidropdown" then
                if popup._popup then popup._popup.Visible = false elseif popup._optionsHolder then popup._optionsHolder.Visible = false end
                popup._indicator.Text = "▼"
                popup._open = false
            elseif popup._type == "buttonbox" then
                popup._optionsHolder.Visible = false
                popup._indicator.Text = "+"
                popup._open = false
            elseif popup._type == "colorpicker" then
                popup._pickerFrame.Visible = false
                popup._open = false
            end
            rem(self._openPopups, i)
        else
            i = i + 1
        end
    end
end

function Window:SetTheme(key, color)
    self._theme[key] = color

    local function applyBindings(bindKey)
        local bindings = self._themeBindings[bindKey]
        if not bindings then return end
        for prop, items in pairs(bindings) do
            for i = #items, 1, -1 do
                if not (items[i] and items[i].Parent) then
                    table.remove(items, i)
                end
            end
            for _, inst in ipairs(items) do
                inst[prop] = color
            end
        end
    end
    if key == "accent" then
        self._accent = color
        applyBindings("accent")
    elseif key == "background" or key == "main" or key == "outline" then
        applyBindings(key)
    elseif key == "fontColor" then
        for _, lbl in pairs(self._labels) do
            if lbl and lbl.Parent then
                lbl.TextColor3 = color
            end
        end
    end
end

function Window:SetToggleKey(key)
    if typeof(key) == "EnumItem" then
        self._toggleKey = key
    end
end

function Window:SetFont(newFont)
    self._font = newFont
    for _, lbl in pairs(self._labels) do
        if lbl and lbl.Parent then
            lbl.Font = newFont
        end
    end
end

function Window:SetTextSize(size)
    self._textSize = size
    for _, lbl in pairs(self._labels) do
        if lbl and lbl.Parent then
