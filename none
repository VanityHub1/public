    win._connections = {}
    win._alive = true

    local function track(conn)
        table.insert(win._connections, conn)
        return conn
    end

    local function getCamera()
        return Workspace.CurrentCamera or Camera
    end


    track(UserInputService.InputBegan:Connect(function(input, gpe)
        local isKeyboard = input.UserInputType == Enum.UserInputType.Keyboard
        local isMouse = input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.MouseButton2
        local isGamepad = input.UserInputType == Enum.UserInputType.Gamepad1

        local kb = win._bindingKeybind
        if kb then
            local key
            if isKeyboard then
                if input.KeyCode == Enum.KeyCode.Escape then
                    if kb._key and kb._key ~= Enum.KeyCode.Unknown then
                        win._keybindMap[tostring(kb._key)] = nil
                    end
                    kb._key = Enum.KeyCode.Unknown
                    kb._kbLabel.Text = "[...]"
                    kb._kbOutline.BorderColor3 = rgb(12, 12, 12)
                    kb._binding = false
                    win._bindingKeybind = nil
                    kb._changedCallback(kb._key, kb._mode)
                    return
                end
                key = input.KeyCode
            elseif isGamepad then
                if input.KeyCode == Enum.KeyCode.ButtonB then
                    if kb._key and kb._key ~= Enum.KeyCode.Unknown then
                        win._keybindMap[tostring(kb._key)] = nil
                    end
                    kb._key = Enum.KeyCode.Unknown
                    kb._kbLabel.Text = "[...]"
                    kb._kbOutline.BorderColor3 = rgb(12, 12, 12)
                    kb._binding = false
                    win._bindingKeybind = nil
                    kb._changedCallback(kb._key, kb._mode)
                    return
                end
                key = input.KeyCode
            elseif kb._allowMouse and isMouse then
                key = input.UserInputType
            end
            if key then
                if kb._key and kb._key ~= Enum.KeyCode.Unknown then
                    win._keybindMap[tostring(kb._key)] = nil
                end
                kb._key = key
                win._keybindMap[tostring(key)] = kb
                local nm = typeof(key) == "EnumItem" and Util.Abbreviate(Util.SplitEnum(key)) or tostring(key)
                kb._kbLabel.Text = "[" .. nm .. "]"
                kb._kbOutline.BorderColor3 = rgb(12, 12, 12)
                kb._binding = false
                win._bindingKeybind = nil
                kb._changedCallback(kb._key, kb._mode)
            end
            return
        end

        if not gpe then
            local key
            if isKeyboard then
                key = input.KeyCode
            elseif isGamepad then
                key = input.KeyCode
            else
                key = input.UserInputType
            end
            local kb = win._keybindMap[tostring(key)]
            if kb then
                if kb._mode == "Toggle" then
                    kb._active = not kb._active
                    kb._callback(kb._active)
                elseif kb._mode == "Hold" then
                    kb._active = true
                    kb._callback(true)
                end
            end
        end
    end))

