        BackgroundTransparency = 1,
        Size = UDim2.new(0, 16, 1, 0),
        Position = UDim2.new(1, -18, 0, 0),
        Font = win._font,
        Text = "▼",
        TextColor3 = Color3.fromRGB(150, 150, 150),
        TextSize = win._textSize - 2,
        TextStrokeTransparency = 0,
        Parent = dropInner
    })

    local clickBtn = Util.Create("TextButton", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 1, 0),
        Text = "",
        Parent = dropBorder
    })

    local itemH = IS_MOBILE and 32 or 22
    local clampedCount = math.clamp(#options, 1, maxVisible)
    local popupH = clampedCount * itemH + 4

    local popup = Util.Create("Frame", {
        BackgroundColor3 = Color3.fromRGB(45, 45, 45),
        BorderSizePixel = 0,
        Size = UDim2.new(0, 200, 0, popupH),
        Visible = false,
        ZIndex = 100,
        Parent = win._screen
    })

    local popupInner = Util.Create("Frame", {
        AnchorPoint = Vector2.new(0.5, 0.5),
        BackgroundColor3 = Color3.fromRGB(22, 22, 22),
        BorderSizePixel = 0,
        Size = UDim2.new(1, -2, 1, -2),
        Position = UDim2.new(0.5, 0, 0.5, 0),
        ZIndex = 100,
        Parent = popup
    })

    local optionsList = Util.Create("ScrollingFrame", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 1, 0),
        ClipsDescendants = true,
        CanvasSize = UDim2.new(0, 0, 0, itemH * #options),
        ScrollBarImageTransparency = 0.4,
        ScrollBarImageColor3 = Color3.fromRGB(80, 80, 80),
        ScrollBarThickness = 4,
        VerticalScrollBarInset = Enum.ScrollBarInset.ScrollBar,
        BorderSizePixel = 0,
        ZIndex = 101,
        Parent = popupInner
    })
    Util.Create("UIListLayout", {
        FillDirection = Enum.FillDirection.Vertical,
        Parent = optionsList
    })

    dd._popup = popup
    dd._indicator = arrow
    dd._valueLbl = valueLbl
    dd._optionsList = optionsList
    dd._dropBorder = dropBorder
    dd._optionLabels = {}

    local function positionPopup()
        local abs = dropBorder.AbsolutePosition
        local absSize = dropBorder.AbsoluteSize
        local screenH = win._screen.AbsoluteSize.Y
        popup.Size = UDim2.new(0, absSize.X, 0, popupH)
        local belowY = abs.Y + absSize.Y + 1
        if belowY + popupH > screenH then

            popup.Position = UDim2.new(0, abs.X, 0, abs.Y - popupH - 1)
        else
            popup.Position = UDim2.new(0, abs.X, 0, belowY)
        end
    end

    for _, opt in pairs(options) do
        local optBtn = Util.Create("TextButton", {
            BackgroundColor3 = Color3.fromRGB(22, 22, 22),
            BackgroundTransparency = 0,
            BorderSizePixel = 0,
            Size = UDim2.new(1, 0, 0, itemH),
            Text = "",
            ZIndex = 102,
            Parent = optionsList
        })
        local optLbl = Util.Create("TextLabel", {
            BackgroundTransparency = 1,
            Size = UDim2.new(1, -12, 1, 0),
            Position = UDim2.new(0, 6, 0, 0),
            Font = win._font,
            Text = opt,
            TextColor3 = opt == default and win._accent or Color3.fromRGB(200, 200, 200),
            TextSize = win._textSize,
            TextStrokeTransparency = 0,
            TextXAlignment = Enum.TextXAlignment.Left,
            ClipsDescendants = true,
            ZIndex = 102,
            Parent = optBtn
        })
        win._labels[#win._labels + 1] = optLbl
        table.insert(dd._optionLabels, optLbl)

        optBtn.MouseEnter:Connect(function()
            optBtn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
        end)
        optBtn.MouseLeave:Connect(function()
            optBtn.BackgroundColor3 = Color3.fromRGB(22, 22, 22)
        end)

        optBtn.MouseButton1Down:Connect(function()
            popup.Visible = false
            dd._open = false
            arrow.Text = "▼"
            for _, lbl in pairs(dd._optionLabels) do
                lbl.TextColor3 = Color3.fromRGB(200, 200, 200)
            end
            dd._value = opt
            valueLbl.Text = opt
            optLbl.TextColor3 = win._accent
            table.insert(win._themeBindings.accent.TextColor3, optLbl)
            callback(opt)
        end)
    end

    clickBtn.MouseButton1Down:Connect(function()
        win:_ClosePopups(dd)
        for _, lbl in pairs(dd._optionLabels) do
            if lbl.Text == dd._value then
                lbl.TextColor3 = win._accent
            else
                lbl.TextColor3 = Color3.fromRGB(200, 200, 200)
            end
        end
        dd._open = not dd._open
        arrow.Text = dd._open and "▲" or "▼"
        if dd._open then
            ins(win._openPopups, dd)
            positionPopup()

            local itemH = 22
            for i, lbl in ipairs(dd._optionLabels) do
                if lbl.Text == dd._value then
                    optionsList.CanvasPosition = vec2(0, (i - 1) * itemH)
                    break
                end
            end
        else
            local idx = table.find(win._openPopups, dd)
            if idx then rem(win._openPopups, idx) end
        end
        popup.Visible = dd._open
    end)

    clickBtn.MouseEnter:Connect(function()
        dropBorder.BackgroundColor3 = Color3.fromRGB(65, 65, 65)
    end)
    clickBtn.MouseLeave:Connect(function()
        dropBorder.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    end)

    table.insert(win._dropdowns, dd)

    local flag = config.Flag or config.Pointer
    if flag and self._flags then
        self._flags[flag] = dd
    end
    if flag and self._window then
        self._window._allFlags[flag] = dd
    end

    return dd
end

function DropdownClass:Set(value)
    if value and table.find(self._options, value) then
        self._value = value
        self._valueLbl.Text = value
        for _, lbl in pairs(self._optionLabels) do
            lbl.TextColor3 = lbl.Text == value and self._window._accent or Color3.fromRGB(200, 200, 200)
        end
        self._callback(value)
    end
end

function DropdownClass:Get()
    return self._value
end

function DropdownClass:Refresh(newOptions, keepValue)
    for _, child in pairs(self._optionsList:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    self._optionLabels = {}
    self._options = newOptions
    local win = self._window
    local itemH = IS_MOBILE and 32 or 22
    local clampedCount = math.clamp(#newOptions, 1, 5)
    self._optionsList.CanvasSize = UDim2.new(0, 0, 0, itemH * #newOptions)
    if self._popup then
        self._popup.Size = UDim2.new(0, self._popup.AbsoluteSize.X, 0, clampedCount * itemH + 4)
    end
    if not keepValue then
        self._value = ""
        self._valueLbl.Text = ""
    end
    for _, opt in pairs(newOptions) do
        local optBtn = Util.Create("TextButton", {
            BackgroundColor3 = Color3.fromRGB(22, 22, 22),
            BackgroundTransparency = 0,
            BorderSizePixel = 0,
            Size = UDim2.new(1, 0, 0, itemH),
            Text = "",
            ZIndex = 102,
            Parent = self._optionsList
        })
        local optLbl = Util.Create("TextLabel", {
            BackgroundTransparency = 1,
            Size = UDim2.new(1, -12, 1, 0),
            Position = UDim2.new(0, 6, 0, 0),
            Font = win._font,
            Text = opt,
            TextColor3 = opt == self._value and win._accent or Color3.fromRGB(200, 200, 200),
            TextSize = win._textSize,
            TextStrokeTransparency = 0,
            TextXAlignment = Enum.TextXAlignment.Left,
            ClipsDescendants = true,
            ZIndex = 102,
            Parent = optBtn
        })
        win._labels[#win._labels + 1] = optLbl
        table.insert(self._optionLabels, optLbl)
        optBtn.MouseEnter:Connect(function()
            optBtn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
        end)
        optBtn.MouseLeave:Connect(function()
            optBtn.BackgroundColor3 = Color3.fromRGB(22, 22, 22)
        end)
        optBtn.MouseButton1Down:Connect(function()
            if self._popup then self._popup.Visible = false end
            self._open = false
            self._indicator.Text = "▼"
            for _, lbl in pairs(self._optionLabels) do
                lbl.TextColor3 = Color3.fromRGB(200, 200, 200)
            end
            self._value = opt
            self._valueLbl.Text = opt
            optLbl.TextColor3 = win._accent
            self._callback(opt)
        end)
    end
end

