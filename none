    local dropBorder = Util.Create("Frame", {
        BackgroundColor3 = Color3.fromRGB(50, 50, 50),
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, dropBtnH),
        Position = UDim2.new(0, 0, 0, 16),
