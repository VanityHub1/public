function Window:CreatePlayersTab(config)
    config = config or {}
    local playersTab = self:CreateTab({ Title = config.Title or "Players" })
    local selfRef = self

    local listSection = playersTab:CreateSection({ Title = "Server Players", Side = "Left" })

    local infoSection = playersTab:CreateSection({ Title = "Player Info", Side = "Right" })
    local actionsSection = playersTab:CreateSection({ Title = "Actions", Side = "Right" })

    local listContainer = listSection._content
    local selectedPlayer = nil

    local noPlayerLabel = Util.Create("TextLabel", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 20),
        Font = self._font,
        Text = "No player selected.",
        TextColor3 = Color3.fromRGB(150, 150, 150),
        TextSize = self._textSize,
        TextStrokeTransparency = 0,
        TextXAlignment = Enum.TextXAlignment.Center,
        Visible = true,
        Parent = listContainer
    })

    local infoLabels = {}
    local infoFields = {"Username", "Display Name", "User ID", "Account Age", "Team", "Health", "Position", "Distance", "Walk Speed", "Jump Power", "Equipped Tool"}
    for _, fieldName in ipairs(infoFields) do
        local lbl = infoSection:CreateLabel({
            Title = fieldName .. ": ---"
        })
        infoLabels[fieldName] = lbl
    end

    actionsSection:CreateButton({
        Title = "Spectate Player",
        Callback = function()
            if selectedPlayer and selectedPlayer.Character then
                local cam = workspace.CurrentCamera
                cam.CameraSubject = selectedPlayer.Character:FindFirstChildOfClass("Humanoid") or selectedPlayer.Character
            end
        end
    })

    actionsSection:CreateButton({
        Title = "Stop Spectating",
        Callback = function()
            pcall(function()
                local cam = workspace.CurrentCamera
                cam.CameraSubject = game:GetService("Players").LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
            end)
        end
    })


    actionsSection:CreateButton({
        Title = "Copy Username",
        Callback = function()
            if selectedPlayer then
                pcall(function() setclipboard(selectedPlayer.Name) end)
                if selfRef.Notify then
                    selfRef:Notify({Title = "Copied", Text = selectedPlayer.Name .. " copied!", Duration = 2})
                end
            end
        end
    })

    actionsSection:CreateButton({
        Title = "Copy User ID",
        Callback = function()
            if selectedPlayer then
                pcall(function() setclipboard(tostring(selectedPlayer.UserId)) end)
            end
        end
    })

    local playerCards = {}
    local accent = selfRef._accent

    local function getDistance(player)
        local dist = 0
        pcall(function()
            local lp = game:GetService("Players").LocalPlayer
            if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") and
               player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                dist = math.floor((lp.Character.HumanoidRootPart.Position - player.Character.HumanoidRootPart.Position).Magnitude)
            end
        end)
        return dist
    end

    local function selectPlayer(player)
        selectedPlayer = player
        noPlayerLabel.Visible = false

        for plr, card in pairs(playerCards) do
            if card.border then
                card.border.BackgroundColor3 = (plr == player) and selfRef._accent or Color3.fromRGB(56, 56, 56)
            end
        end

    end

    local function updatePlayerInfo()
        if not selectedPlayer then return end
        local plr = selectedPlayer
        local char = plr.Character

        local function safeSet(field, value)
            if infoLabels[field] and infoLabels[field]._label then
                infoLabels[field]._label.Text = field .. ": " .. tostring(value)
            end
        end

        safeSet("Username", plr.Name)
        safeSet("Display Name", plr.DisplayName)
        safeSet("User ID", plr.UserId)
        safeSet("Account Age", plr.AccountAge .. " days")
        safeSet("Team", plr.Team and plr.Team.Name or "None")

        if char then
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then
                safeSet("Health", math.floor(hum.Health) .. " / " .. math.floor(hum.MaxHealth))
                safeSet("Walk Speed", hum.WalkSpeed)
                safeSet("Jump Power", hum.JumpPower)
            end
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp then
                safeSet("Position", math.floor(hrp.Position.X) .. ", " .. math.floor(hrp.Position.Y) .. ", " .. math.floor(hrp.Position.Z))
            end
            safeSet("Distance", getDistance(plr) .. " studs")
            local tool = char:FindFirstChildOfClass("Tool")
            safeSet("Equipped Tool", tool and tool.Name or "None")
        else
            safeSet("Health", "No Character")
            safeSet("Position", "N/A")
            safeSet("Distance", "N/A")
            safeSet("Walk Speed", "N/A")
            safeSet("Jump Power", "N/A")
            safeSet("Equipped Tool", "N/A")
        end
    end

    local function createPlayerCard(player)
        if playerCards[player] then return end

        local cardBorder = Util.Create("Frame", {
            BackgroundColor3 = Color3.fromRGB(56, 56, 56),
            Size = UDim2.new(1, 0, 0, 44),
            Parent = listContainer
        })

        local cardInner = Util.Create("Frame", {
            AnchorPoint = Vector2.new(0.5, 0.5),
            BackgroundColor3 = Color3.fromRGB(25, 25, 25),
            BorderSizePixel = 0,
            Size = UDim2.new(1, -2, 1, -2),
            Position = UDim2.new(0.5, 0, 0.5, 0),
            Parent = cardBorder
        })

        local avatarFrame = Util.Create("ImageLabel", {
            AnchorPoint = Vector2.new(0, 0.5),
            BackgroundColor3 = Color3.fromRGB(35, 35, 35),
            BorderSizePixel = 0,
            Size = UDim2.new(0, 34, 0, 34),
            Position = UDim2.new(0, 5, 0.5, 0),
            Parent = cardInner
        })

        pcall(function()
            local thumbType = Enum.ThumbnailType.HeadShot
            local thumbSize = Enum.ThumbnailSize.Size48x48
            local content = game:GetService("Players"):GetUserThumbnailAsync(player.UserId, thumbType, thumbSize)
            avatarFrame.Image = content
        end)

        Util.Create("UICorner", {
            CornerRadius = UDim.new(0, 4),
            Parent = avatarFrame
        })

        local nameLabel = Util.Create("TextLabel", {
            AnchorPoint = Vector2.new(0, 0),
            BackgroundTransparency = 1,
            Size = UDim2.new(1, -90, 0, 20),
            Position = UDim2.new(0, 44, 0, 2),
            Font = selfRef._font,
            Text = player.DisplayName,
            TextColor3 = Color3.fromRGB(255, 255, 255),
            TextSize = selfRef._textSize,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextTruncate = Enum.TextTruncate.AtEnd,
            Parent = cardInner
        })
        selfRef._labels[#selfRef._labels + 1] = nameLabel

        local userLabel = Util.Create("TextLabel", {
            AnchorPoint = Vector2.new(0, 0),
            BackgroundTransparency = 1,
            Size = UDim2.new(1, -90, 0, 18),
            Position = UDim2.new(0, 44, 0, 22),
            Font = selfRef._font,
            Text = "@" .. player.Name,
            TextColor3 = Color3.fromRGB(140, 140, 140),
            TextSize = selfRef._textSize - 2,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextTruncate = Enum.TextTruncate.AtEnd,
            Parent = cardInner
        })
        selfRef._labels[#selfRef._labels + 1] = userLabel

        local healthBg = Util.Create("Frame", {
            AnchorPoint = Vector2.new(1, 0.5),
            BackgroundColor3 = Color3.fromRGB(40, 40, 40),
            BorderSizePixel = 0,
            Size = UDim2.new(0, 40, 0, 6),
            Position = UDim2.new(1, -5, 0.5, 0),
            Parent = cardInner
        })

        local healthFill = Util.Create("Frame", {
            BackgroundColor3 = Color3.fromRGB(0, 255, 0),
            BorderSizePixel = 0,
            Size = UDim2.new(1, 0, 1, 0),
            Parent = healthBg
        })

        Util.Create("UICorner", { CornerRadius = UDim.new(0, 2), Parent = healthBg })
        Util.Create("UICorner", { CornerRadius = UDim.new(0, 2), Parent = healthFill })

        local clickBtn = Util.Create("TextButton", {
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 1, 0),
            Text = "",
            Parent = cardInner
        })

        clickBtn.MouseButton1Click:Connect(function()
            selectPlayer(player)
            updatePlayerInfo()
        end)

        clickBtn.MouseEnter:Connect(function()
            if selectedPlayer ~= player then
                cardInner.BackgroundColor3 = Color3.fromRGB(32, 32, 32)
            end
        end)
        clickBtn.MouseLeave:Connect(function()
            if selectedPlayer ~= player then
                cardInner.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
            end
        end)

        playerCards[player] = {
            border = cardBorder,
            inner = cardInner,
            nameLabel = nameLabel,
            userLabel = userLabel,
            healthFill = healthFill,
            avatar = avatarFrame,
        }
    end

    local function removePlayerCard(player)
        if playerCards[player] then
            playerCards[player].border:Destroy()
            playerCards[player] = nil
            if selectedPlayer == player then
                selectedPlayer = nil
                noPlayerLabel.Visible = true

                for field, lbl in pairs(infoLabels) do
                    if lbl._label then
                        lbl._label.Text = field .. ": ---"
                    end
                end
            end
        end
    end

    local Players = game:GetService("Players")
    for _, plr in ipairs(Players:GetPlayers()) do
        task.spawn(createPlayerCard, plr)
    end

    Players.PlayerAdded:Connect(function(plr)
        task.spawn(createPlayerCard, plr)
    end)

    Players.PlayerRemoving:Connect(function(plr)
        removePlayerCard(plr)
    end)

    task.spawn(function()
        while selfRef._alive and task.wait(0.5) do
            for plr, card in pairs(playerCards) do
                pcall(function()
                    if plr.Character then
                        local hum = plr.Character:FindFirstChildOfClass("Humanoid")
                        if hum then
                            local pct = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
                            card.healthFill.Size = UDim2.new(pct, 0, 1, 0)
                            if pct > 0.5 then
                                card.healthFill.BackgroundColor3 = Color3.fromRGB(
                                    math.floor(255 * (1 - pct) * 2), 255, 0
                                )
                            else
                                card.healthFill.BackgroundColor3 = Color3.fromRGB(
                                    255, math.floor(255 * pct * 2), 0
                                )
                            end
                        end
                    end
                end)
            end
            if selectedPlayer then
                pcall(updatePlayerInfo)
            end
        end
    end)

    return playersTab
end

function Window:SetKeybindListVisible(bool)
    if not self._keybindList then
        self._keybindList = self:CreateKeybindList({})
    end
    self._keybindList:SetVisible(bool)
end

function Window:Destroy()

    self._alive = false

    if self._autosaveRunning then
        self._autosaveRunning = false
        self._autosaveThread = nil
    end

    if self._connections then
        for _, conn in pairs(self._connections) do
            if conn and typeof(conn) == "RBXScriptConnection" and conn.Connected then
                conn:Disconnect()
            end
        end
        self._connections = {}
    end

    self._labels = {}
    self._tabs = {}
    self._flags = {}
    self._dropdowns = {}
    self._multidrops = {}
    self._buttonboxes = {}
    self._colorpickers = {}
    self._keybindElements = {}
    self._activeSliders = {}
    self._notifQueue = {}
    if self._themeBindings then
        for _, propTable in pairs(self._themeBindings) do
            for _, items in pairs(propTable) do
                for i = #items, 1, -1 do items[i] = nil end
            end
        end
    end

    if self._screen then
        pcall(function() self._screen:SetAttribute("_InjectAlive", false) end)
        self._screen:Destroy()
    end
end


return Inject
