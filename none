function ElementMixin:CreateSlider(config)
    config = config or {}
    local name = config.Title or config.Name or "Slider"
    local default = config.Default or 0
    local min = config.Min or 0
    local max = config.Max or 100

    local decimals = config.Decimals
    local rounding
    if config.Rounding ~= nil then
        rounding = config.Rounding
    elseif config.Round ~= nil then
        rounding = config.Round
    else
        rounding = (decimals == nil)
    end
    if not decimals then decimals = 0 end
    local suffix = config.Suffix or config.Measurement or ""
    local callback = config.Callback or function() end
    local win = self._window
    default = math.clamp(default, min, max)

    local slider = setmetatable({}, SliderClass)
    slider._window = win
    slider._min = min
    slider._max = max
    slider._value = default
    slider._rounding = rounding
    slider._decimals = decimals
    slider._suffix = suffix
    slider._callback = callback
    slider._holding = false

    local holder = Util.Create("Frame", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, IS_MOBILE and 32 or 25),
        Parent = self._content
    })

    local titleLbl = Util.Create("TextLabel", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 15),
        Font = win._font,
        Text = name,
        TextColor3 = Color3.fromRGB(255, 255, 255),
        TextSize = Util.MobileTextSize(win._textSize),
        TextStrokeTransparency = 0,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = holder
    })
    win._labels[#win._labels + 1] = titleLbl

    local sliderBarH = IS_MOBILE and 18 or 12
    local outline = Util.Create("Frame", {
        BackgroundColor3 = Color3.fromRGB(24, 24, 24),
        BorderColor3 = Color3.fromRGB(12, 12, 12),
        BorderMode = Enum.BorderMode.Inset,
        BorderSizePixel = 1,
        Size = UDim2.new(1, 0, 0, sliderBarH),
        Position = UDim2.new(0, 0, 0, 15),
        Parent = holder
    })

    local innerBg = Util.Create("Frame", {
        BackgroundColor3 = Color3.fromRGB(30, 30, 30),
        BorderColor3 = Color3.fromRGB(56, 56, 56),
        BorderMode = Enum.BorderMode.Inset,
        BorderSizePixel = 1,
        Size = UDim2.new(1, 0, 1, 0),
        Parent = outline
    })

    local bgColor = Util.Create("Frame", {
        BackgroundColor3 = Color3.fromRGB(30, 30, 30),
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 1, 0),
        Parent = innerBg
    })
    ApplyGradient(bgColor)

    local valueLbl = Util.Create("TextLabel", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 2),
        Position = UDim2.new(0, 0, 0.5, 0),
        Font = win._font,
        Text = default .. suffix,
        TextColor3 = Color3.fromRGB(255, 255, 255),
        TextSize = win._textSize,
        TextStrokeTransparency = 0,
        ZIndex = 3,
        Parent = outline
    })
    win._labels[#win._labels + 1] = valueLbl

    local initFill = 0
    if max ~= min then
        initFill = (default - min) / (max - min)
    end
    local slideBar = Util.Create("Frame", {
        BackgroundColor3 = win._accent,
        BorderSizePixel = 0,
        Size = UDim2.new(initFill, 0, 1, 0),
        ZIndex = 2,
        Parent = outline
    })
    table.insert(win._themeBindings.accent.BackgroundColor3, slideBar)
    ApplyGradient(slideBar)

    slider._bgColor  = bgColor
    slider._outline  = outline
    slider._slideBar = slideBar
    slider._valueLbl = valueLbl
    slider._holder   = holder

    local clickBtn = Util.Create("TextButton", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 1, 0),
        Text = "",
        Parent = holder
    })

    local function doSlide()
        local absX = bgColor.AbsolutePosition.X
        local absW = bgColor.AbsoluteSize.X
        local mouseX = math.clamp(LocalPlayer:GetMouse().X - absX, 0, absW)
        local ratio = mouseX / absW
        local result = min + (max - min) * ratio
        if rounding then
            result = math.floor(result)
        else
            result = Util.Round(result, decimals)
        end
        slider._value = result
        valueLbl.Text = result .. suffix
        slideBar:TweenSize(UDim2.new(ratio, 0, 1, 0), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.15, true)
        callback(result)
    end

    clickBtn.MouseButton1Down:Connect(function()
        slider._holding = true
        doSlide()
        outline.BorderColor3 = win._accent
        table.insert(win._themeBindings.accent.BorderColor3, outline)
    end)

    UserInputService.InputChanged:Connect(function()
        if slider._holding then doSlide() end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 and slider._holding then
            slider._holding = false
            outline.BorderColor3 = rgb(12, 12, 12)
            local idx = table.find(win._themeBindings.accent.BorderColor3, outline)
            if idx then rem(win._themeBindings.accent.BorderColor3, idx) end
        end
    end)

    table.insert(win._activeSliders, slider)

    local flag = config.Flag or config.Pointer
    if flag and self._flags then
        self._flags[flag] = slider
    end
    if flag and self._window then
        self._window._allFlags[flag] = slider
    end

    return slider
end

function SliderClass:Set(value)
    value = math.clamp(value, self._min, self._max)
    local ratio = (value - self._min) / (self._max - self._min)
    if self._rounding then value = math.floor(value) else value = Util.Round(value, self._decimals or 0) end
    self._value = value
    self._valueLbl.Text = value .. self._suffix
    self._slideBar:TweenSize(UDim2.new(ratio, 0, 1, 0), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.15, true)
    self._callback(value)
end

function SliderClass:Get()
    return self._value
end

function ElementMixin:CreateDropdown(config)
