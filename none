function Util.Create(class, props)
    local inst = Instance.new(class)

    local parentVal = props.Parent
    for k, v in pairs(props) do
        if k ~= "Parent" then
            local ok, _ = pcall(function() inst[k] = v end)
            if not ok then

            end
        end
    end
    if parentVal then
        inst.Parent = parentVal
    end
    return inst
end

function Util.MakeDraggable(handle, frame, connectionsTable)
    local dragStart, startPos, moveConn
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragStart = input.Position
            startPos  = frame.Position
            if moveConn then moveConn:Disconnect() end
            moveConn = UserInputService.InputChanged:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseMovement or inp.UserInputType == Enum.UserInputType.Touch then
                    local delta = inp.Position - dragStart
                    frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
                end
            end)
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    if moveConn then moveConn:Disconnect(); moveConn = nil end
                end
            end)
        end
    end)
    if connectionsTable then
        table.insert(connectionsTable, moveConn)
    end
end

function Util.Round(n, decimals)
    return tonumber(string.format("%." .. (decimals or 0) .. "f", n))
end

function Util.Abbreviate(keyName)
    local map = {
        RightShift = "RS", LeftShift = "LS",
        RightControl = "RC", LeftControl = "LC",
        RightAlt = "RA", LeftAlt = "LA",
        RightBracket = "RB", LeftBracket = "LB",
        CapsLock = "CAPS", Backspace = "BS",
        Return = "RET", Escape = "ESC",
        Delete = "DEL", Insert = "INS",
        PageUp = "PgUp", PageDown = "PgDn",
        NumLock = "NUM", ScrollLock = "SCRL",
        Backquote = "`", Minus = "-", Equals = "=",
        Semicolon = ";", Quote = "'", Backslash = "\\",
        Comma = ",", Period = ".", Slash = "/",
        Space = "SPC", Tab = "TAB",
        MouseButton1 = "M1", MouseButton2 = "M2", MouseButton3 = "M3",

        ButtonA = "A", ButtonB = "B", ButtonX = "X", ButtonY = "Y",
        ButtonL1 = "LB", ButtonR1 = "RB",
        ButtonL2 = "LT", ButtonR2 = "RT",
        ButtonL3 = "LS", ButtonR3 = "RS",
        ButtonStart = "START", ButtonSelect = "SELECT",
        DPadUp = "D-Up", DPadDown = "D-Dn",
        DPadLeft = "D-Lt", DPadRight = "D-Rt",
        Thumbstick1 = "LS", Thumbstick2 = "RS",
    }
    if map[keyName] then return map[keyName] end

    if keyName:match("^F%d+$") then return keyName end

    if #keyName <= 3 then return keyName end

    local caps = ""
    for c in keyName:gmatch("%u") do caps = caps .. c end
    return #caps > 1 and caps or keyName
end

function Util.SplitEnum(enum)
    local parts = tostring(enum):split(".")
    return parts[#parts]
end

function Util.ToHex(color)
    return string.format("#%02X%02X%02X", color.R * 255, color.G * 255, color.B * 255)
end

function Util.FromHex(hex)
    local r, g, b = hex:match("^#?(%w%w)(%w%w)(%w%w)$")
    return Color3.fromRGB(tonumber(r, 16), tonumber(g, 16), tonumber(b, 16))
end

function Util.StripSpaces(s)
    return s:gsub(" ", "")
end

local IS_MOBILE = UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled
local MOBILE_SCALE = IS_MOBILE and 1.15 or 1
local MOBILE_PAD   = IS_MOBILE and 6 or 0

function Util.MobileTextSize(base)
    return math.floor(base * MOBILE_SCALE)
end

function Util.MobileTouchSize(base)

    if IS_MOBILE then
        return math.max(base, 30)
    end
    return base
end

