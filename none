function KeybindClass:Set(key)
    local win = self._window
    if self._key and self._key ~= Enum.KeyCode.Unknown and win and win._keybindMap then
        win._keybindMap[tostring(self._key)] = nil
    end
    self._key = key
    if key ~= Enum.KeyCode.Unknown and win and win._keybindMap then
        win._keybindMap[tostring(key)] = self
    end
    local nm = typeof(key) == "EnumItem" and Util.Abbreviate(Util.SplitEnum(key)) or tostring(key)
    self._kbLabel.Text = "[" .. nm .. "]"
    self._changedCallback(key, self._mode)
end

function KeybindClass:SetMode(mode)
    if mode == "Toggle" or mode == "Hold" or mode == "Always" then
        self._mode = mode
        for m, l in pairs(self._modeLabels) do
            l.TextColor3 = m == mode and self._window._accent or Color3.fromRGB(255, 255, 255)
        end
        if mode == "Always" then self._active = true end
        self._changedCallback(self._key, mode)
    end
end

function KeybindClass:Get()
    return self._key, self._mode
end

function KeybindClass:IsActive()
    return self._active
end

