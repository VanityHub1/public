        if isKeyboard then
            key = input.KeyCode
        elseif isGamepad then
            key = input.KeyCode
        else
            key = input.UserInputType
        end
        local kb = win._keybindMap[tostring(key)]
        if kb and kb._mode == "Hold" and not kb._binding then
            kb._active = false
            kb._callback(false)
        end
    end))

