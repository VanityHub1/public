local function _applyDisabledOverlay(holder, enabled)
    if not holder then return end
    local overlay = holder:FindFirstChild("_DisabledOverlay")
    if not enabled then
        if not overlay then
            overlay = Instance.new("Frame")
            overlay.Name = "_DisabledOverlay"
            overlay.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
            overlay.BackgroundTransparency = 0.55
            overlay.BorderSizePixel = 0
            overlay.Size = UDim2.new(1, 0, 1, 0)
            overlay.ZIndex = 99
            overlay.Parent = holder
        end
        overlay.Visible = true
    else
        if overlay then overlay.Visible = false end
    end
end

local function _pruneLabels(win, holder)
    if not holder or not win._labels then return end
    for i = #win._labels, 1, -1 do
        local lbl = win._labels[i]
        if not lbl or not lbl.Parent then
            table.remove(win._labels, i)
        elseif lbl:IsDescendantOf(holder) then
            table.remove(win._labels, i)
        end
    end
end

