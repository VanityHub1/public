    dd._window = win
    dd._options = options
    dd._value = default
    dd._open = false
    dd._value = default
    dd._callback = callback
    dd._type = "dropdown"

    local holder = Util.Create("Frame", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, IS_MOBILE and 46 or 38),
        Parent = self._content
    })

    local titleLbl = Util.Create("TextLabel", {
        BackgroundTransparency = 1,
