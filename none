    table.insert(win._multidrops, md)

    local flag = config.Flag or config.Pointer
    if flag and self._flags then
        self._flags[flag] = md
    end
    if flag and self._window then
        self._window._allFlags[flag] = md
    end

    return md
end

function MultiDropdownClass:Refresh(newOptions, keepValue)

    for _, child in pairs(self._optionsList:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    self._optionLabels = {}
    self._options = newOptions
    local win = self._window
    local itemH = IS_MOBILE and 32 or 22
    local clampedCount = math.clamp(#newOptions, 1, 4)
    self._optionsList.CanvasSize = UDim2.new(0, 0, 0, itemH * #newOptions)
    if self._popup then
        self._popup.Size = UDim2.new(0, self._popup.AbsoluteSize.X, 0, clampedCount * itemH + 4)
    end
    if not keepValue then
        self._value = {}
        self._valueLbl.Text = ""
    else
        local filtered = {}
        for _, v in pairs(self._value) do
            if table.find(newOptions, v) then table.insert(filtered, v) end
        end
        self._value = filtered
        self._valueLbl.Text = table.concat(self._value, ", ")
    end
    for _, opt in pairs(newOptions) do
        local isSelected = table.find(self._value, opt) ~= nil
        local optBtn = Util.Create("TextButton", {
            BackgroundColor3 = Color3.fromRGB(22, 22, 22),
            BackgroundTransparency = 0,
            BorderSizePixel = 0,
            Size = UDim2.new(1, 0, 0, itemH),
            Text = "",
            ZIndex = 102,
            Parent = self._optionsList
        })
        local optLbl = Util.Create("TextLabel", {
            BackgroundTransparency = 1,
            Size = UDim2.new(1, -12, 1, 0),
            Position = UDim2.new(0, 6, 0, 0),
            Font = win._font,
            Text = opt,
            TextColor3 = isSelected and win._accent or Color3.fromRGB(200, 200, 200),
            TextSize = win._textSize,
            TextStrokeTransparency = 0,
            TextXAlignment = Enum.TextXAlignment.Left,
            ClipsDescendants = true,
            ZIndex = 102,
            Parent = optBtn
        })
        win._labels[#win._labels + 1] = optLbl
        table.insert(self._optionLabels, optLbl)
        optBtn.MouseEnter:Connect(function() optBtn.BackgroundColor3 = Color3.fromRGB(35, 35, 35) end)
        optBtn.MouseLeave:Connect(function() optBtn.BackgroundColor3 = Color3.fromRGB(22, 22, 22) end)
        optBtn.MouseButton1Down:Connect(function()
            local idx = table.find(self._value, opt)
            if idx then
                table.remove(self._value, idx)
                optLbl.TextColor3 = Color3.fromRGB(200, 200, 200)
            else
                table.insert(self._value, opt)
                optLbl.TextColor3 = win._accent
            end
            self._valueLbl.Text = table.concat(self._value, ", ")
            self._callback(self._value)
        end)
    end
end

function MultiDropdownClass:Set(tbl)
    if typeof(tbl) ~= "table" then return end
    self._value = {}
    for _, v in pairs(tbl) do
        if table.find(self._options, v) then
            table.insert(self._value, v)
        end
    end
    for _, lbl in pairs(self._optionLabels) do
        lbl.TextColor3 = table.find(self._value, lbl.Text) and self._window._accent or Color3.fromRGB(255, 255, 255)
    end
    self._valueLbl.Text = table.concat(self._value, ", ")
    self._callback(self._value)
end

function MultiDropdownClass:Get()
    return self._value
end

