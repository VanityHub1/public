function Window:Notify(config)
    config = config or {}
    local title    = config.Title or "Notification"
    local bodyText = config.Text
    local duration = config.Duration or 3
    local hasBody  = bodyText and bodyText ~= ""

    local notifBorder = Util.Create("Frame", {
        AnchorPoint      = Vector2.new(1, 1),
        BackgroundColor3 = self._accent,
        BorderColor3     = Color3.fromRGB(12, 12, 12),
        BorderSizePixel  = 1,
        Size             = UDim2.new(0, 160, 0, 0),
        AutomaticSize    = Enum.AutomaticSize.Y,
        Position         = UDim2.new(3, 0, 1, -15),
        Parent           = self._screen
    })

    local notifBlack = Util.Create("Frame", {
        BackgroundColor3 = Color3.fromRGB(0, 0, 0),
        BorderColor3     = Color3.fromRGB(12, 12, 12),
        BorderSizePixel  = 1,
        Size             = UDim2.new(1, -4, 1, -4),
        Position         = UDim2.new(0, 2, 0, 2),
        AutomaticSize    = Enum.AutomaticSize.Y,
        Parent           = notifBorder
    })

    local notifInner = Util.Create("Frame", {
        BackgroundColor3 = Color3.fromRGB(20, 20, 20),
        BorderColor3     = Color3.fromRGB(56, 56, 56),
        BorderMode       = Enum.BorderMode.Inset,
        BorderSizePixel  = 1,
        Size             = UDim2.new(1, 0, 1, 0),
        AutomaticSize    = Enum.AutomaticSize.Y,
        Parent           = notifBlack
    })

    Util.Create("UIListLayout", {
        FillDirection   = Enum.FillDirection.Vertical,
        SortOrder       = Enum.SortOrder.LayoutOrder,
        Padding         = UDim.new(0, 2),
        Parent          = notifInner
    })

    Util.Create("UIPadding", {
        PaddingLeft   = UDim.new(0, 10),
        PaddingRight  = UDim.new(0, 10),
        PaddingTop    = UDim.new(0, 6),
        PaddingBottom = UDim.new(0, 6),
        Parent        = notifInner
    })

    local notifTitle = Util.Create("TextLabel", {
        BackgroundTransparency = 1,
        Size                   = UDim2.new(1, 0, 0, 0),
        AutomaticSize          = Enum.AutomaticSize.Y,
        Font                   = self._font,
        Text                   = title,
        TextColor3             = Color3.fromRGB(255, 255, 255),
        TextSize               = self._textSize,
        TextXAlignment         = Enum.TextXAlignment.Left,
        TextWrapped            = true,
        TextStrokeTransparency = 0,
        LayoutOrder            = 1,
        Parent                 = notifInner
    })
    self._labels[#self._labels + 1] = notifTitle

    if hasBody then
        local notifBody = Util.Create("TextLabel", {
            BackgroundTransparency = 1,
            Size                   = UDim2.new(1, 0, 0, 0),
            AutomaticSize          = Enum.AutomaticSize.Y,
            Font                   = self._font,
            Text                   = bodyText,
            TextColor3             = Color3.fromRGB(180, 180, 180),
            TextSize               = math.max(self._textSize - 2, 10),
            TextXAlignment         = Enum.TextXAlignment.Left,
            TextWrapped            = true,
            TextStrokeTransparency = 0.5,
            LayoutOrder            = 2,
            Parent                 = notifInner
        })
        self._labels[#self._labels + 1] = notifBody
    end

    local notifH = 65
    table.insert(self._notifQueue, notifBorder)
    local qIdx = #self._notifQueue
    local yOff = -15 - (qIdx - 1) * notifH

    task.spawn(function()
        task.wait(0.05)
        TweenService:Create(notifBorder, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Position = UDim2.new(1, -15, 1, yOff)
        }):Play()
        task.wait(duration)

        local idx = table.find(self._notifQueue, notifBorder)
        if idx then table.remove(self._notifQueue, idx) end
        for i, nb in ipairs(self._notifQueue) do
            TweenService:Create(nb, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                Position = UDim2.new(1, -15, 1, -15 - (i - 1) * notifH)
            }):Play()
        end
        TweenService:Create(notifBorder, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
            Position = UDim2.new(3, 0, 1, yOff)
        }):Play()
        task.wait(0.6)
        notifBorder:Destroy()
    end)
end

function Window:CreateKeybindList(config)
    config = config or {}
    local visible = config.Visible
    if visible == nil then visible = true end

    local kblBorder = Util.Create("Frame", {
        AnchorPoint = Vector2.new(0, 0),
        BackgroundColor3 = self._accent,
        BorderColor3 = Color3.fromRGB(12, 12, 12),
        BorderSizePixel = 1,
        Size = UDim2.new(0, IS_MOBILE and 200 or 180, 0, 28),
        Position = UDim2.new(0, 15, 0, 60),
        AutomaticSize = Enum.AutomaticSize.Y,
        Visible = visible,
        Parent = self._screen
    })
    table.insert(self._themeBindings.accent.BackgroundColor3, kblBorder)

    local kblBlack = Util.Create("Frame", {
        BackgroundColor3 = Color3.fromRGB(0, 0, 0),
        BorderColor3 = Color3.fromRGB(12, 12, 12),
        BorderSizePixel = 1,
        Size = UDim2.new(1, -4, 1, -4),
        Position = UDim2.new(0, 2, 0, 2),
        Parent = kblBorder
    })

    local kblInner = Util.Create("Frame", {
        BackgroundColor3 = Color3.fromRGB(20, 20, 20),
        BorderColor3 = Color3.fromRGB(56, 56, 56),
        BorderMode = Enum.BorderMode.Inset,
        BorderSizePixel = 1,
        Size = UDim2.new(1, 0, 1, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        Parent = kblBlack
    })

    local kblTitle = Util.Create("TextLabel", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, IS_MOBILE and 28 or 24),
        Font = self._font,
        Text = "Keybinds",
        TextColor3 = Color3.fromRGB(255, 255, 255),
        TextSize = Util.MobileTextSize(self._textSize),
        TextStrokeTransparency = 0,
        Parent = kblInner
    })
    self._labels[#self._labels + 1] = kblTitle

    local kblList = Util.Create("Frame", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 0),
        Position = UDim2.new(0, 0, 0, IS_MOBILE and 28 or 24),
        AutomaticSize = Enum.AutomaticSize.Y,
        Parent = kblInner
    })
    Util.Create("UIListLayout", {
        FillDirection = Enum.FillDirection.Vertical,
        Parent = kblList
    })

    Util.MakeDraggable(kblBorder, kblBorder, self._connections)

    local kbl = {
        _window = self,
        _frame = kblBorder,
        _list = kblList,
        _inner = kblInner,
        _entries = {},
        _visible = visible
    }

    local modeOrder = {"Toggle", "Hold", "Always"}

    local function getNameKeyText(kb)
        local rawKey = typeof(kb._key) == "EnumItem" and Util.SplitEnum(kb._key) or tostring(kb._key)
        local keyText = Util.Abbreviate(rawKey)
        return "  " .. kb._name .. " [" .. keyText .. "]"
    end

    local function createEntry(kb)
        local rowH = IS_MOBILE and 28 or 20
        local color = kb._active and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 255, 255)

        local holder = Util.Create("Frame", {
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 0, rowH),
            ClipsDescendants = false,
            Parent = kblList
        })

        local lbl = Util.Create("TextLabel", {
            BackgroundTransparency = 1,
            Size = UDim2.new(1, -54, 1, 0),
            Font = self._font,
            Text = getNameKeyText(kb),
            TextColor3 = color,
            TextSize = Util.MobileTextSize(self._textSize),
            TextStrokeTransparency = 0,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextTruncate = Enum.TextTruncate.AtEnd,
            Parent = holder
        })

        local modeBtnBorder = Util.Create("Frame", {
            AnchorPoint = Vector2.new(1, 0.5),
            BackgroundColor3 = Color3.fromRGB(40, 40, 40),
            BorderSizePixel = 0,
            Size = UDim2.new(0, 50, 0, IS_MOBILE and 20 or 16),
            Position = UDim2.new(1, -2, 0.5, 0),
            Parent = holder
        })

        local modeBtnInner = Util.Create("Frame", {
            AnchorPoint = Vector2.new(0.5, 0.5),
            BackgroundColor3 = Color3.fromRGB(25, 25, 25),
            BorderSizePixel = 0,
            Size = UDim2.new(1, -2, 1, -2),
            Position = UDim2.new(0.5, 0, 0.5, 0),
            Parent = modeBtnBorder
        })

        local modeLbl = Util.Create("TextLabel", {
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 1, 0),
            Font = self._font,
            Text = kb._mode,
            TextColor3 = Color3.fromRGB(200, 200, 200),
            TextSize = Util.MobileTextSize(self._textSize) - 2,
            TextStrokeTransparency = 0,
            Parent = modeBtnInner
        })

        local modeClick = Util.Create("TextButton", {
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 1, 0),
            Text = "",
            Parent = modeBtnBorder
        })

        local modeItemH = IS_MOBILE and 26 or 20
        local modePopup = Util.Create("Frame", {
            AnchorPoint = Vector2.new(1, 0),
            BackgroundColor3 = Color3.fromRGB(40, 40, 40),
            BorderSizePixel = 0,
            Size = UDim2.new(0, 50, 0, modeItemH * 3 + 2),
            Position = UDim2.new(1, -2, 1, 1),
            Visible = false,
            ZIndex = 100,
            Parent = holder
        })

        local modePopupInner = Util.Create("Frame", {
            AnchorPoint = Vector2.new(0.5, 0.5),
            BackgroundColor3 = Color3.fromRGB(22, 22, 22),
            BorderSizePixel = 0,
            Size = UDim2.new(1, -2, 1, -2),
            Position = UDim2.new(0.5, 0, 0.5, 0),
            ZIndex = 100,
            Parent = modePopup
        })

        Util.Create("UIListLayout", {
            FillDirection = Enum.FillDirection.Vertical,
            Parent = modePopupInner
        })

        local modeOptionLabels = {}
        for _, mode in pairs(modeOrder) do
            local optBtn = Util.Create("TextButton", {
                BackgroundColor3 = Color3.fromRGB(22, 22, 22),
                BorderSizePixel = 0,
                Size = UDim2.new(1, 0, 0, modeItemH),
                Text = "",
                ZIndex = 101,
                Parent = modePopupInner
            })

            local optLbl = Util.Create("TextLabel", {
                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 1, 0),
                Font = self._font,
                Text = mode,
                TextColor3 = mode == kb._mode and self._accent or Color3.fromRGB(200, 200, 200),
                TextSize = Util.MobileTextSize(self._textSize) - 2,
                TextStrokeTransparency = 0,
                ZIndex = 101,
                Parent = optBtn
            })
            modeOptionLabels[mode] = optLbl

            optBtn.MouseEnter:Connect(function()
                optBtn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
            end)
            optBtn.MouseLeave:Connect(function()
                optBtn.BackgroundColor3 = Color3.fromRGB(22, 22, 22)
            end)

            optBtn.MouseButton1Down:Connect(function()
                kb:SetMode(mode)
                modeLbl.Text = mode
                modePopup.Visible = false
                for m, l in pairs(modeOptionLabels) do
                    l.TextColor3 = m == mode and self._accent or Color3.fromRGB(200, 200, 200)
                end
            end)
        end

        modeClick.MouseButton1Down:Connect(function()
            modePopup.Visible = not modePopup.Visible
            if modePopup.Visible then
                for m, l in pairs(modeOptionLabels) do
                    l.TextColor3 = m == kb._mode and self._accent or Color3.fromRGB(200, 200, 200)
                end
            end
        end)

        return {
            row = holder,
            label = lbl,
            modeLbl = modeLbl,
            modePopup = modePopup,
            modeOptionLabels = modeOptionLabels
        }
    end

    local function rebuildKeybindList()
        local boundSet = {}

        for _, kb in pairs(self._keybindElements) do
            if kb._key ~= Enum.KeyCode.Unknown then
                boundSet[kb] = true

                if not kbl._entries[kb] then
                    kbl._entries[kb] = createEntry(kb)
                else
                    kbl._entries[kb].label.Text = getNameKeyText(kb)
                    kbl._entries[kb].modeLbl.Text = kb._mode
                    if kbl._entries[kb].modeOptionLabels then
                        for m, l in pairs(kbl._entries[kb].modeOptionLabels) do
                            l.TextColor3 = m == kb._mode and self._accent or Color3.fromRGB(200, 200, 200)
                        end
                    end
                end

                kbl._entries[kb].label.TextColor3 = kb._active
                    and Color3.fromRGB(0, 255, 0)
                    or  Color3.fromRGB(255, 255, 255)
            end
        end

        for kb, entry in pairs(kbl._entries) do
            if not boundSet[kb] then
                entry.row:Destroy()
                kbl._entries[kb] = nil
            end
        end
    end

    local kblPrevStates = {}
    local kblPrevKeys = {}
    local kblPrevModes = {}
    local kblLastUpdate = 0

    table.insert(self._connections, RunService.Heartbeat:Connect(function()
        if not kbl._visible then return end
        if not self._alive then return end

        local now = tick()
        if now - kblLastUpdate < 0.2 then return end

        local changed = false
        for _, kb in pairs(self._keybindElements) do
            if kblPrevStates[kb] ~= kb._active or kblPrevKeys[kb] ~= kb._key or kblPrevModes[kb] ~= kb._mode then
                changed = true
                break
            end
        end
        if not changed then return end

        kblLastUpdate = now
        for _, kb in pairs(self._keybindElements) do
            kblPrevStates[kb] = kb._active
            kblPrevKeys[kb] = kb._key
            kblPrevModes[kb] = kb._mode
        end
        rebuildKeybindList()
    end))

    rebuildKeybindList()

    function kbl:SetVisible(bool)
        kbl._visible = bool
        kbl._frame.Visible = bool
    end

    return kbl
end

local function _collectFlags(flagsTable, out)
    if type(flagsTable) ~= "table" then return end
    for k, v in pairs(flagsTable) do
        if type(v) == "table" then
            if v.Get then

                local ok, val = pcall(function() return v:Get() end)
                if ok then
                    if typeof(val) == "Color3" then
                        out[k] = {Type = "Color3", R = val.R, G = val.G, B = val.B}
                    elseif typeof(val) == "EnumItem" then
                        out[k] = {Type = "EnumItem", Value = tostring(val)}
                    else
                        out[k] = val
                    end
                end

                if v._mode ~= nil then
                    out[k .. "__mode"] = v._mode
                end
            else

                _collectFlags(v, out)
            end
        end
    end
end

function Window:SaveConfig()
    local data = {}

    for k, v in pairs(self._allFlags) do
        if type(v) == "table" and v.Get then
            local ok, val = pcall(function() return v:Get() end)
            if ok then
                if typeof(val) == "Color3" then
                    data[k] = {Type = "Color3", R = val.R, G = val.G, B = val.B}
                elseif typeof(val) == "EnumItem" then
                    data[k] = {Type = "EnumItem", Value = tostring(val)}
                else
                    data[k] = val
                end
            end
            if v._mode ~= nil then
                data[k .. "__mode"] = v._mode
            end
        end
    end
    return HttpService:JSONEncode(data)
end

function Window:LoadConfig(jsonStr)
    local ok, data = pcall(HttpService.JSONDecode, HttpService, jsonStr)
    if not ok or type(data) ~= "table" then return end

    local elemMap = self._allFlags

    for k, v in pairs(data) do
        if type(k) == "string" and k:sub(-6) == "__mode" then
            local baseKey = k:sub(1, -7)
            local elem = elemMap[baseKey]
            if elem and elem.SetMode then
                pcall(function() elem:SetMode(v) end)
            end
        end
    end

    for k, v in pairs(data) do
        if not (type(k) == "string" and k:sub(-6) == "__mode") then
            local elem = elemMap[k]
            if elem and elem.Set then
                pcall(function()
                    if type(v) == "table" and v.Type == "Color3" then
                        elem:Set(Color3.new(v.R or 0, v.G or 0, v.B or 0))
                    elseif type(v) == "table" and v.Type == "EnumItem" then
                        local parts = string.split(v.Value, ".")
                        if parts[2] and parts[3] then
                            elem:Set(Enum[parts[2]][parts[3]])
                        end
                    else
                        elem:Set(v)
                    end
                end)
            end
        end
    end
end

function Window:_cfgPath(name)

    return tostring(game and game.PlaceId or 0) .. "_" .. name .. ".cfg"
end

function Window:_autoloadPath()

    return tostring(game and game.PlaceId or 0) .. "_autoload.txt"
end

function Window:SaveConfigFile(name)

    pcall(function()
        if writefile then
            writefile(self:_cfgPath(name), self:SaveConfig())
        end
    end)
end

function Window:LoadConfigFile(name)
    pcall(function()
        if isfile and readfile then
            local path = self:_cfgPath(name)
            if isfile(path) then
                self:LoadConfig(readfile(path))
            end
        end
    end)
end

function Window:DeleteConfigFile(name)
    pcall(function()
        local path = self:_cfgPath(name)
        if delfile then
            delfile(path)
        elseif writefile then
            writefile(path, "")
        end
    end)
end

function Window:SetAutoload(name)
    pcall(function()
        if writefile then
            writefile(self:_autoloadPath(), name)
        end
    end)
end

function Window:GetAutoloadName()
    local name = nil
    pcall(function()
        if isfile and readfile then
            local path = self:_autoloadPath()
            if isfile(path) then
                name = readfile(path)
                if name then name = name:match("^%s*(.-)%s*$") end
            end
        end
    end)
    return name
end

function Window:TryAutoload()
    local name = self:GetAutoloadName()
    if name and #name > 0 then
        self:LoadConfigFile(name)
    end
end

function Window:EnableAutosave(interval)
    interval = interval or 5
    if self._autosaveThread then return end

    local path = tostring(game and game.PlaceId or 0) .. "_autosave.cfg"

    pcall(function()
        if isfile and readfile and isfile(path) then
            self:LoadConfig(readfile(path))
        end
    end)

    local lastJson = ""
    self._autosaveRunning = true
    self._autosaveThread = task.spawn(function()
        while self._autosaveRunning and self._alive do
            task.wait(interval)
            if not self._autosaveRunning then break end
            pcall(function()
                if writefile then
                    local ok, json = pcall(function() return self:SaveConfig() end)
                    if ok and json ~= lastJson then
                        writefile(path, json)
                        lastJson = json
                    end
                end
            end)
        end
    end)
end

function Window:DisableAutosave()
    if not self._autosaveThread then return end
    self._autosaveRunning = false
    self._autosaveThread = nil

    pcall(function()
        if writefile then
            local ok, json = pcall(function() return self:SaveConfig() end)
            if ok then
                writefile(tostring(game and game.PlaceId or 0) .. "_autosave.cfg", json)
            end
        end
    end)
end

function Window:ClearAutosave()
    pcall(function()
        local path = tostring(game and game.PlaceId or 0) .. "_autosave.cfg"
        if delfile then delfile(path)
        elseif writefile then writefile(path, "{}") end
    end)
end

