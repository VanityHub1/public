        cp._color = Color3.fromHSV(cp._hsv[1], cp._hsv[2], cp._hsv[3])
        previewColor.BackgroundColor3 = cp._color
        updateBoxes()
        callback(cp._color)
        svCursor:TweenPosition(UDim2.new(ratioX, 0, ratioY, 0), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.12, true)
    end

    previewBtn.MouseButton1Down:Connect(function()
        win:_ClosePopups(cp)
        if not cp._open then

            local absPos = previewOut.AbsolutePosition
            local absSize = previewOut.AbsoluteSize
            local screenSize = win._screen.AbsoluteSize
            local px = absPos.X + absSize.X - 200
            local py = absPos.Y + absSize.Y + 4

            if py + 230 > screenSize.Y then
                py = absPos.Y - 234
            end

            if px < 4 then px = 4 end
            pickerFrame.Position = UDim2.new(0, px, 0, py)
        end
        pickerFrame.Visible = not cp._open
        cp._open = not cp._open
        if cp._open then
            ins(win._openPopups, cp)
        else
            local idx = table.find(win._openPopups, cp)
            if idx then rem(win._openPopups, idx) end
        end
    end)

    hueBtn.MouseButton1Down:Connect(function()
        cp._draggingH = true
        moveHue()
    end)

    svBtn.MouseButton1Down:Connect(function()
        cp._draggingSV = true
        moveSV()
    end)

    UserInputService.InputChanged:Connect(function()
        if cp._draggingSV then moveSV() end
        if cp._draggingH then moveHue() end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            cp._draggingSV = false
            cp._draggingH = false
        end
    end)

    local function handleRGB(tb, channel)
        tb.FocusLost:Connect(function()
            local num = tonumber(tb.Text)
            if num then
                num = math.clamp(num, 0, 255)
                local r, g, b = cp._color.R * 255, cp._color.G * 255, cp._color.B * 255
                if channel == "r" then r = num elseif channel == "g" then g = num else b = num end
                cp._color = Color3.fromRGB(r, g, b)
                cp._hsv[1], cp._hsv[2], cp._hsv[3] = Color3.toHSV(cp._color)
                previewColor.BackgroundColor3 = cp._color
                svArea.BackgroundColor3 = Color3.fromHSV(cp._hsv[1], 1, 1)
                svCursor.Position = UDim2.new(cp._hsv[2], 0, 1 - cp._hsv[3], 0)
                hueCursor.Position = UDim2.new(0.5, 0, cp._hsv[1], 0)
                updateBoxes()
                callback(cp._color)
            end

            updateBoxes()
        end)
    end
    handleRGB(redTB, "r")
    handleRGB(greenTB, "g")
    handleRGB(blueTB, "b")

    hexTB.FocusLost:Connect(function()
        local success, col = pcall(Util.FromHex, hexTB.Text)
        if success and col then
            cp._color = col
            cp._hsv[1], cp._hsv[2], cp._hsv[3] = Color3.toHSV(col)
            previewColor.BackgroundColor3 = col
            svArea.BackgroundColor3 = Color3.fromHSV(cp._hsv[1], 1, 1)
            svCursor.Position = UDim2.new(cp._hsv[2], 0, 1 - cp._hsv[3], 0)
            hueCursor.Position = UDim2.new(0.5, 0, cp._hsv[1], 0)
            updateBoxes()
            callback(col)
        end

        updateBoxes()
    end)

    table.insert(win._colorpickers, cp)

    local flag = config.Flag or config.Pointer
    if flag and self._flags then
        self._flags[flag] = cp
    end
    if flag and self._window then
        self._window._allFlags[flag] = cp
    end

    return cp
end

