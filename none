    local default = config.Default or false
    local callback = config.Callback or function() end
    local win = self._window

    local toggle = setmetatable({}, ToggleClass)
    toggle._window = win
    toggle._callback = callback
    toggle._value = default

    local toggleSize = IS_MOBILE and 20 or 15
    local holder = Util.Create("Frame", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, Util.MobileTouchSize(15)),
        Parent = self._content
    })

    local outline = Util.Create("Frame", {
        BackgroundColor3 = Color3.fromRGB(24, 24, 24),
        BorderColor3 = Color3.fromRGB(12, 12, 12),
        BorderMode = Enum.BorderMode.Inset,
        BorderSizePixel = 1,
        Size = UDim2.new(0, toggleSize, 0, toggleSize),
        AnchorPoint = Vector2.new(0, 0.5),
        Position = UDim2.new(0, 0, 0.5, 0),
        Parent = holder
    })

    local col = default and win._accent or Color3.fromRGB(20, 20, 20)
    local checkFill = Util.Create("Frame", {
        BackgroundColor3 = col,
        BorderColor3 = Color3.fromRGB(56, 56, 56),
        BorderMode = Enum.BorderMode.Inset,
        BorderSizePixel = 1,
        Size = UDim2.new(1, 0, 1, 0),
        Parent = outline
    })
    ApplyGradient(checkFill)

    if default then
        table.insert(win._themeBindings.accent.BackgroundColor3, checkFill)
    end

    local titleLbl = Util.Create("TextLabel", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -(toggleSize + 5), 1, 0),
        Position = UDim2.new(0, toggleSize + 5, 0, 0),
        Font = win._font,
        Text = name,
        TextColor3 = Color3.fromRGB(255, 255, 255),
        TextSize = Util.MobileTextSize(win._textSize),
        TextStrokeTransparency = 0,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = holder
    })
    win._labels[#win._labels + 1] = titleLbl

    local btn = Util.Create("TextButton", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 1, 0),
        Text = "",
        Parent = holder
    })

    toggle._fill   = checkFill
    toggle._holder = holder

    btn.MouseButton1Down:Connect(function()
        toggle._value = not toggle._value
        if toggle._value then
            checkFill.BackgroundColor3 = win._accent
            table.insert(win._themeBindings.accent.BackgroundColor3, checkFill)
        else
            checkFill.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
            local idx = table.find(win._themeBindings.accent.BackgroundColor3, checkFill)
            if idx then table.remove(win._themeBindings.accent.BackgroundColor3, idx) end
        end
        toggle._callback(toggle._value)
    end)

    local flag = config.Flag or config.Pointer
    if flag and self._flags then
        self._flags[flag] = toggle
    end
    if flag and self._window then
        self._window._allFlags[flag] = toggle
    end

    return toggle
end

function ToggleClass:Set(bool)
    if bool == nil then return end
    self._value = bool
    if bool then
        self._fill.BackgroundColor3 = self._window._accent
        table.insert(self._window._themeBindings.accent.BackgroundColor3, self._fill)
    else
        self._fill.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
        local idx = table.find(self._window._themeBindings.accent.BackgroundColor3, self._fill)
        if idx then table.remove(self._window._themeBindings.accent.BackgroundColor3, idx) end
    end
    self._callback(bool)
end

function ToggleClass:Get()
    return self._value
end

