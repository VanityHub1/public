local function MakeBorderedBox(props)
    local outer = Util.Create("Frame", {
        BackgroundColor3 = props.OuterColor or Color3.fromRGB(24, 24, 24),
        BorderColor3 = props.OuterBorder or Color3.fromRGB(12, 12, 12),
        BorderMode = Enum.BorderMode.Inset,
        BorderSizePixel = 1,
        Size = props.Size or UDim2.new(1, 0, 1, 0),
        Position = props.Position or UDim2.new(0, 0, 0, 0),
        AnchorPoint = props.AnchorPoint or Vector2.new(0, 0),
        ZIndex = props.ZIndex or 1,
        Parent = props.Parent
    })
    local inner = Util.Create("Frame", {
        BackgroundColor3 = props.InnerColor or Color3.fromRGB(24, 24, 24),
        BorderColor3 = props.InnerBorder or Color3.fromRGB(56, 56, 56),
        BorderMode = Enum.BorderMode.Inset,
        BorderSizePixel = 1,
        Size = UDim2.new(1, 0, 1, 0),
        ZIndex = props.ZIndex or 1,
        Parent = outer
    })
    return outer, inner
end

