                    SetIconButtonSize(Objects.NotifButton, 16)
                    SetIconButtonSize(Objects.ConfigButton, 16)
                    SetIconButtonSize(Objects.MobileModeButton, 18)
                    Objects.ToggleOpenButton.Size = UDim2.fromOffset(42, 42)
                    Objects.ToggleOpenButton.Position = UDim2.new(0, 14, 1, -56)
                end

                Objects.Outline.Size = UDim2.fromOffset(OutlineWidth, OutlineHeight)

                local MaxX = math.max(ViewportSize.X - OutlineWidth, 0)
                local MaxY = math.max(ViewportSize.Y - OutlineHeight, 0)
                local OutlinePosition = Objects.Outline.AbsolutePosition
                local X = Window.IsMobile and math.floor(MaxX / 2) or math.clamp(OutlinePosition.X, 0, MaxX)
                local Y = Window.IsMobile and math.floor(MaxY / 2) or math.clamp(OutlinePosition.Y, 0, MaxY)

                Objects.Outline.Position = UDim2.new(0, X, 0, Y)

                for _, tab in Window.Tabs do
                    if tab.UpdateLayout then
                        tab.UpdateLayout(Window.IsMobile)
                    end
                end

                Window.UpdateBottomBarLayout()
                Window.UpdateMobileButton()
                Window.UpdateMobileModeButton()
