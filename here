            end

            if IconType ~= "string" then
                return icon
            end

            if icon == "" then
                return nil
            end

            if icon:find("rbxassetid://", 1, true) == 1 or icon:find("http://", 1, true) == 1 or icon:find("https://", 1, true) == 1 then
                return icon
            end

            local NumericIcon = tonumber(icon)
            if NumericIcon then
                return "rbxassetid://" .. tostring(NumericIcon)
            end

            local IconMap = GetIconMap()
            local Resolved = IconMap[icon] or IconMap[icon:lower()]
            if Resolved then
                return "rbxassetid://" .. tostring(Resolved)
            end

            return icon
