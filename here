-- bin
    local BinLib = {
        methods = {
            ["function"] = true,
            thread = true,
            RBXScriptConnection = "Disconnect"
        }
    }; do
        function BinLib.bin()
            local bin = { 
                storage = {} 
            }
    
            function bin:add(item, method)
                if item == nil or not self.storage then
                    return item
                end

                local entry = { main = item }
                entry.destroy = function()
                    local itemType = typeof(item)
                    local destroyMethod = method or BinLib.methods[itemType] or "Destroy"

                    if destroyMethod == true then
                        if type(item) == "function" then
                            pcall(item)
                        elseif itemType == "thread" then
                            pcall(task.cancel, item)
                        end
                    else
                        local callMethod = item and item[destroyMethod]
                        if callMethod then
                            pcall(callMethod, item)
                        end
                    end
                end

                table.insert(self.storage, entry)
                return item
            end

            function bin:destroy()
                if not (self and self.storage) then return end

                for i = #self.storage, 1, -1 do
                    local entry = self.storage[i]
                    if entry and entry.destroy then
                        entry.destroy()
                    end
                end

                table.clear(self.storage)
                self.storage = nil
            end
    
            return bin    
        end
    end; Inject.BinLib = BinLib; local Bin = BinLib.bin(); Inject.Bin = Bin
