            -- Colorpickers store shared configs as { c = Color3, a = number }.
            -- Accept both raw Color3 values and config tables so theme/config callbacks
            -- cannot accidentally assign a table to BackgroundColor3/TextColor3.
            if type(color) == "table" then
                color = color.c or color.Color or color.color
            end

            if typeof(color) ~= "Color3" then
                return
            end

            Library.Theme[theme] = color

            for _,themeobj in Library.ThemeObjects do
                for prop,val in themeobj.Props do
                    if val == theme then
                        if themeobj.Tween then
                            themeobj.Tween:Cancel()
                        end

                        themeobj.Object[prop] = color
