                    table.insert(Tab.Sections, ColumnObject)

                    Utility.New("UIListLayout", {
                        Name = "UIListLayout",
                        Parent = ColumnObject,
                        FillDirection = Enum.FillDirection.Vertical,
                        SortOrder = Enum.SortOrder.LayoutOrder,
                        Padding = UDim.new(0, 4),
                    })

                    -- Add padding at bottom of column
                    Utility.New("UIPadding", {
                        Name = "BottomPadding",
                        Parent = ColumnObject,
                        PaddingBottom = UDim.new(0, 40),
                    })

                    Tab[Column.Key] = ColumnObject
                end

                -- aliases so old section calls still work
                Tab.center = Tab.middle
                Tab.mid = Tab.middle

                function Tab.UpdateLayout(isMobile)
                    if isMobile then
                        local PageWidth = Objects.Page.AbsoluteSize.X
                        if PageWidth <= 0 then
                            PageWidth = Objects.Page.Parent.AbsoluteSize.X
                        end

                        local Gap = 6
                        local ColumnWidth = math.max(PageWidth - 12, 220)

                        for index, Column in ipairs(ColumnData) do
                            local ColumnObject = Tab[Column.Key]
                            ColumnObject.Size = UDim2.new(0, ColumnWidth, 0, 0)
                            ColumnObject.Position = UDim2.new(0, (index - 1) * (ColumnWidth + Gap), 0, 0)
                        end

                        Objects.Page.ScrollingEnabled = true
                        Objects.Page.ScrollBarThickness = 2
                        Objects.Page.ScrollBarImageTransparency = 0.35
                        Objects.Page.ScrollingDirection = Enum.ScrollingDirection.XY
                        Objects.Page.AutomaticCanvasSize = Enum.AutomaticSize.Y
                        Objects.Page.CanvasSize = UDim2.new(0, (#ColumnData * ColumnWidth) + ((#ColumnData - 1) * Gap), 0, 0)
                    else
                        for _, Column in ColumnData do
                            local ColumnObject = Tab[Column.Key]
                            ColumnObject.Size = UDim2.new(1/3, -3, 0, 0)
                            ColumnObject.Position = Column.Position
                        end

                        -- Desktop: enable vertical scrolling when content overflows
                        Objects.Page.ScrollingEnabled = true
                        Objects.Page.ScrollBarThickness = 2
                        Objects.Page.ScrollBarImageTransparency = 0.35
                        Objects.Page.ScrollingDirection = Enum.ScrollingDirection.Y
                        Objects.Page.AutomaticCanvasSize = Enum.AutomaticSize.Y
                        Objects.Page.CanvasPosition = Vector2.new()
                        Objects.Page.CanvasSize = UDim2.new(0, 0, 0, 0)
                    end
                end

                Tab.UpdateLayout(Window.IsMobile)
            end; Tab.ZIndex = ZIndex

            function Tab.Set(status, nested)
                Library.Tween(Objects.SubTabButton, {
                    BackgroundTransparency = status and 0.85 or 1,
                })

                Library.ChangeObjectTheme(Objects.SubTabText, {
                    TextColor3 = status and "Text" or "Dark Text",
                }, true)

                if Objects.SubTabIcon then
                    Library.ChangeObjectTheme(Objects.SubTabIcon, {
                        ImageColor3 = status and "Text" or "Dark Text",
                    }, true)
                end

                Objects.Page.Visible = status

                if status and Window.ScrollSubTabIntoView then
                    task.defer(function()
                        Window.ScrollSubTabIntoView(Objects.SubTabButton)
                    end)
                end

                if not Window.TabsTweening then 
                    if not nested then
                        Window.TabsTweening = true

                        for _,tab in Window.Tabs do
                            if tab.Name == Tab.Name then continue end

                            tab.Set(false, true)
                        end

                        -- if self.TabsTweening then
                        --     return
                        -- end

                        for _,obj in Objects.Page:GetDescendants() do
                            local Index = Utility.GetTransparency(obj)

                            if not Index then continue end

                            if type(Index) == "table" then
                                for _,prop in Index do
                                    Library.Fade(obj, prop, status)
                                end
                            else
                                Library.Fade(obj, Index, status)
                            end
                        end

                        Objects.Page.Position = status and UDim2.fromOffset(0, 20) or UDim2.fromOffset(0, 0)

                        local Tween = Library.Tween(Objects.Page, {
                            Position = status and UDim2.fromOffset(0, 0) or UDim2.fromOffset(0, 20),
                        })

                        Utility.Signal(Tween.Completed:Connect(function()
                            Window.TabsTweening = false
                        end))
                    end
                end
            end

            Utility.Signal(Objects.SubTabButton.MouseButton1Click:Connect(function()
                Tab.Set(true)
            end))

            table.insert(Window.Tabs, Tab)

            -- If this is the first tab in an already-active category, show it immediately.
            if Category and Window.ActiveCategory == Category and #Category.Tabs == 1 then
                Objects.SubTabButton.Visible = true
                task.defer(function()
                    Tab.Set(true)
                end)
            end
            
            return setmetatable(Tab, Library)
        end

