        local NotificationClock = 0
        function Library.HandleNotifications(step)
            if step and step > 0 then
                NotificationClock += step
                if NotificationClock >= 0.25 then
                    Library.Fps = math.floor(1 / step)
                    NotificationClock = 0
                end
            end

            if #Library.Notifications == 0 then
                return
            end

            local Clock = os.clock()
            local Watermark = Library.ScreenGui:FindFirstChild("Watermark")
            local Offset = Watermark and Watermark.Visible and Watermark.AbsoluteSize.Y + 5 or 0

            for i = #Library.Notifications, 1, -1 do
                local notification = Library.Notifications[i]
                local Objects = notification.Objects

                local Time = notification.Time
                
                if Clock - notification.Clock >= Time then
                    notification.Lerp = Utility.Lerp(notification.Lerp, 0, 0.1)
                else
                    notification.Lerp = Utility.Lerp(notification.Lerp, 255, 0.1)
                end

                local Lerp = notification.Lerp

                local Holder = Objects.Holder
                local Outline = Objects.Outline
                local Background = Objects.Background
                local Title = Objects.Title

                Holder.Position = UDim2.new(0, 10 + (-Holder.AbsoluteSize.X * (1 - (Lerp / 255))), 0, Offset)

                Outline.BackgroundTransparency = 1 - (Lerp / 255)
                Background.BackgroundTransparency = 1 - (Lerp / 255)
                Title.TextTransparency = 1 - (Lerp / 255)

                if #notification.Buttons > 0 then
                    notification.ButtonLerp = Utility.Lerp(notification.ButtonLerp, notification.ShowButtons and 255 or 0, 0.1)
                    
                    for _,obj in Objects.ButtonHolder:GetDescendants() do
                        local Index = Utility.GetTransparency(obj)

                        if not Index then
                            continue
                        end

                        if type(Index) == "table" then
                            if obj:IsA("TextLabel") then
                                obj[Index[1]] = 1 - (notification.ButtonLerp / 255)
                            else
                                obj[Index[1]] = 1 - (notification.ButtonLerp / 255)
                                obj[Index[2]] = 1 - (notification.ButtonLerp / 255)
                            end
                        else
                            obj[Index] = 1 - (notification.ButtonLerp / 255)
                        end
                    end
                end

                if Objects.Description then
                    Objects.Description.TextTransparency = 1 - (Lerp / 255)
                end

                if Objects.Time then
                    Objects.Time.BackgroundTransparency = 1 - (Lerp / 255)
                    Objects.Time.Size = UDim2.new(0, (Outline.AbsoluteSize.X - 10) * math.clamp(((notification.Clock - Clock) / notification.Time) * -1, 0, 1), 0, 2)
                end

                Offset += (Holder.AbsoluteSize.Y + 5) * (Lerp / 255)

                if Lerp <= 0 then
                    Holder:Destroy()
                    table.remove(Library.Notifications, i)
                    continue
                end
            end
        end; Utility.Signal(RunService.RenderStepped:Connect(Library.HandleNotifications))

        function Library.GetConfig()
            local Config = { }

            for _,v in Library.ConfigFlags do
                local Value = Library.Flags[_]

                if type(Value) == "table" and Value["key"] then
                    Config[_] = {value = Value.value, mode = Value.mode, key = tostring(Value.key)}
                elseif type(Value) == "table" and Value["a"] and Value["c"] then
                    Config[_] = {a = Value.a, c = Value.c:ToHex()}
                else
                    Config[_] = Value
                end
            end

            return HttpService:JSONEncode(Config)
        end

        function Library.LoadConfig(data)
            data = HttpService:JSONDecode(data)

            for i,v in data do
                local Config = Library.ConfigFlags[i]

                if Config then
                    if type(v) == "table" and v["a"] and v["c"] then
                        Config({
                            a = v.a,
                            c = type(v.c) == "string" and Color3.fromHex(v.c) or v.c
                        })
                    elseif type(v) == "table" and v["key"] then
                        Config({
                            value = v.value,
                            mode = v.mode,
                            key = Utility.StringToEnum(v.key)
                        }, true)
                    else
                        Config(v)
                    end
                end
            end
        end


        -- ═══════════════════════════════════════════════════════════════
        -- AUTOLOAD SYSTEM (per-game using PlaceId)
        -- ═══════════════════════════════════════════════════════════════
        local function CanUseFilesForAutoload()
            return type(writefile) == "function" and type(readfile) == "function" and type(isfile) == "function"
        end

        local function GetAutoloadPath()
            local placeId = tostring(game.PlaceId or "0")
            return "Inject_AutoLoad_" .. placeId .. ".txt"
        end

        function Library.SetAutoLoad(configName)
            if not CanUseFilesForAutoload() then return false end
            local path = GetAutoloadPath()
            if configName == nil or configName == "" then
                if type(delfile) == "function" and isfile(path) then
                    pcall(delfile, path)
                end
                return true
            end
            local ok = pcall(writefile, path, tostring(configName))
            return ok
        end

        function Library.GetAutoLoad()
            if not CanUseFilesForAutoload() then return nil end
            local path = GetAutoloadPath()
            if not isfile(path) then return nil end
            local ok, data = pcall(readfile, path)
            if ok and type(data) == "string" and data ~= "" then
                return (data:gsub("^%s+", ""):gsub("%s+$", ""))
            end
            return nil
        end

        function Library.AutoLoadConfig()
            if not CanUseFilesForAutoload() then return false end
            local configName = Library.GetAutoLoad()
            if not configName or configName == "" then return false end
            local safe = configName:gsub("[^%w%-%_ ]", ""):gsub("%s+", "_")
            if safe == "" then return false end
            local path = "Inject_" .. safe .. ".json"
            if not isfile(path) then return false end
            local ok, data = pcall(readfile, path)
            if not ok or type(data) ~= "string" then return false end
            local success = pcall(function()
                Library.LoadConfig(data)
            end)
            if success then
                task.spawn(function()
                    task.wait(0.5)
                    Library.Notification({ name = "Auto Load", description = "Loaded config: " .. configName, time = 3 })
                end)
                return true
            end
            return false
        end

        function Library.CreateConfigPanel(window)
            local Panel = { Visible = false, Window = window, Objects = {}, SavedButtons = {} }
            local ZIndex = 9000
            local Objects = Panel.Objects
            Objects.Buttons = {}

            local function Notify(title, description)
                Library.Notification({ Name = title or "Inject Config", Description = description or "", Time = 3 })
            end

            local function CanUseFiles()
                return type(writefile) == "function" and type(readfile) == "function" and type(isfile) == "function"
            end

            local function CanListFiles()
                return CanUseFiles() and type(listfiles) == "function"
            end

            local function Trim(text)
                return tostring(text or ""):gsub("^%s+", ""):gsub("%s+$", "")
            end

            local function SanitizeConfigName(name)
                name = Trim(name):gsub("[^%w%-%_ ]", ""):gsub("%s+", "_")
                return name ~= "" and name or nil
            end

            local function ConfigPath(name)
                local safe = SanitizeConfigName(name)
                return safe and ("Inject_" .. safe .. ".json") or nil
            end

            local function DisplayName(path)
                local name = tostring(path or ""):gsub("\\", "/"):match("([^/]+)$") or tostring(path or "")
                return (name:gsub("^Inject_", ""):gsub("%.json$", ""))
            end

            local function DecodeConfig(text)
                if type(text) ~= "string" or text:gsub("%s+", "") == "" then
                    return false, "Paste a JSON config first."
                end

                local ok, decoded = pcall(function()
                    return HttpService:JSONDecode(text)
                end)

                if not ok or type(decoded) ~= "table" then
                    return false, "Invalid JSON config."
                end

                return true, decoded
            end

            local function ApplyConfig(text)
                local ok, decoded = DecodeConfig(text)
                if not ok then
                    return false, decoded
                end

                local success, err = pcall(function()
                    Library.LoadConfig(HttpService:JSONEncode(decoded))
                end)

                if not success then
                    return false, tostring(err)
                end

                return true
            end

            local function ReadConfig(path)
                if not CanUseFiles() then
                    return false, "Your executor does not support workspace files."
                end

                if not isfile(path) then
                    return false, path .. " was not found."
                end

                local ok, data = pcall(readfile, path)
                if not ok then
                    return false, "Read failed: " .. tostring(data)
                end

                return true, data
            end

            local function ListConfigs()
                if not CanListFiles() then
                    return {}
                end

                local roots = { "", "." }
                local seen, configs = {}, {}

                for _, root in ipairs(roots) do
                    local ok, files = pcall(listfiles, root)
                    if ok and type(files) == "table" then
                        for _, path in ipairs(files) do
                            local file = tostring(path):gsub("\\", "/"):match("([^/]+)$") or tostring(path)
                            if file:match("^Inject_.+%.json$") and not seen[file] then
                                seen[file] = true
                                table.insert(configs, { Path = path, File = file, Name = DisplayName(file) })
                            end
                        end
                    end
                end

                table.sort(configs, function(a, b)
                    return a.Name:lower() < b.Name:lower()
                end)

                return configs
            end

