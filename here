                }, { ScrollBarImageColor3 = "Accent" })

                -- Register tab with its category
                if Category then
                    table.insert(Category.Tabs, Tab)
                end

                ZIndex += 1

                -- 3 column layout: Left / Middle / Right
                local ColumnData = {
                    { Key = "left", Name = "Left", Position = UDim2.new(0, 0, 0, 0) },
                    { Key = "middle", Name = "Middle", Position = UDim2.new(1/3, 2, 0, 0) },
                    { Key = "right", Name = "Right", Position = UDim2.new(2/3, 4, 0, 0) },
                }

                for _, Column in ColumnData do
                    local ColumnObject = Utility.New("Frame", {
                        Name = Column.Name,
                        BackgroundTransparency = 1,
                        BorderSizePixel = 0,
                        Size = UDim2.new(1/3, -3, 0, 0),
                        AutomaticSize = Enum.AutomaticSize.Y,
