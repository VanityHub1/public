        function Library.IsMoveInput(input)
            return input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch
        end

        function Library.GetInputPosition(input)
            return input and input.Position or UserInputService:GetMouseLocation()
        end

        function Library.Resize(holder, box)
            local Start, StartSize, Resizing;
            local CurrentSize = holder.Size
            local OriginalSize = holder.Size
        
            Utility.Signal(box.InputBegan:Connect(function(input)
                if Library.IsPressInput(input) then
                    Resizing = true
                    Start = Library.GetInputPosition(input)
                    StartSize = holder.Size
                end
            end))
        
            Utility.Signal(UserInputService.InputChanged:Connect(function(input)
                if Library.IsMoveInput(input) and Resizing then
                    local ViewportSize = Camera.ViewportSize
                    local Position = Library.GetInputPosition(input)
                    CurrentSize = UDim2.new(0, math.clamp(StartSize.X.Offset + (Position.X - Start.X), OriginalSize.X.Offset, ViewportSize.x), 0, math.clamp(StartSize.Y.Offset + (Position.Y - Start.Y), OriginalSize.Y.Offset, ViewportSize.y))
                    holder.Size = CurrentSize
                end
            end))
        
            Utility.Signal(UserInputService.InputEnded:Connect(function(input)
                if Library.IsPressInput(input) then
                    Resizing = false
                end
            end))
        end
        
        function Library.Dragging(holder, box, dragSpeed)
            -- Touch devices feel best with shorter tween drag so the window stays under the finger.
            dragSpeed = dragSpeed or (UserInputService.TouchEnabled and 0.075 or 0.13)

            local Dragging = false
            local DragOffset = Vector2.new()
            local DragTween = nil

            local function ToVector2(position)
                if typeof(position) == "Vector3" then
                    return Vector2.new(position.X, position.Y)
                end

                return position
            end

            local LastDragPosition = nil
            local DragInfo = TweenInfo.new(dragSpeed, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

            local function TweenTo(position)
                if LastDragPosition then
                    local dx = math.abs(position.X.Offset - LastDragPosition.X.Offset)
                    local dy = math.abs(position.Y.Offset - LastDragPosition.Y.Offset)
                    if dx < 1 and dy < 1 then
                        return
                    end
                end

                LastDragPosition = position

                if DragTween then
                    DragTween:Cancel()
                end

                DragTween = TweenService:Create(holder, DragInfo, {
                    Position = position,
                })
                DragTween:Play()
            end

            Utility.Signal(box.InputBegan:Connect(function(input)
                if Library.IsPressInput(input) then
                    Dragging = true
                    local mouse = ToVector2(Library.GetInputPosition(input))
                    DragOffset = mouse - holder.AbsolutePosition
                end
            end))

            Utility.Signal(UserInputService.InputChanged:Connect(function(input)
                if not (Dragging and Library.IsMoveInput(input)) then
                    return
                end

                local mouse = ToVector2(Library.GetInputPosition(input))
                local viewport = Camera.ViewportSize
                local size = holder.AbsoluteSize
                local parent = holder.Parent
                local parentAbs = parent and parent.AbsolutePosition or Vector2.new()
                local anchor = holder.AnchorPoint

                local topLeft = mouse - DragOffset
                topLeft = Vector2.new(
                    math.clamp(topLeft.X, 0, math.max(0, viewport.X - size.X)),
                    math.clamp(topLeft.Y, 0, math.max(0, viewport.Y - size.Y))
                )

                local anchored = topLeft - parentAbs + Vector2.new(size.X * anchor.X, size.Y * anchor.Y)
                TweenTo(UDim2.fromOffset(anchored.X, anchored.Y))
            end))

            Utility.Signal(UserInputService.InputEnded:Connect(function(input)
                if Library.IsPressInput(input) then
                    Dragging = false
                    LastDragPosition = nil
                end
            end))
        end

