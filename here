            function Window:SetMobileSupport(enabled)
                self.MobileEnabled = enabled ~= false
                if not self.MobileEnabled then
                    self.ForceMobile = false
                end

                self.UpdateLayout()
                self.UpdateMobileModeButton()
            end

            function Window:SetMobileMode(enabled)
                self.ForceMobile = enabled == true
                if self.ForceMobile then
                    self.MobileEnabled = true
                end

                self.UpdateLayout()
                self.UpdateMobileModeButton()
            end

            function Window:ToggleMobileMode()
                if self.IsMobile and not self.ForceMobile then
                    self.MobileEnabled = false
                elseif not self.IsMobile and not self.MobileEnabled then
                    self.MobileEnabled = true
                elseif self.ForceMobile then
                    self.ForceMobile = false
                else
                    self.ForceMobile = true
                    self.MobileEnabled = true
                end

                self.UpdateLayout()
                self.UpdateMobileModeButton()

                if Library.Notification then
                    Library.Notification({
                        Name = "Inject",
                        Description = "Mobile mode " .. (self.IsMobile and "enabled" or "disabled"),
                        Time = 2,
                    })
                end
            end

