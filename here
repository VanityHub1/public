    local function GetIconMap()
        if CachedIconMap then
            return CachedIconMap
        end

        CachedIconMap = {}

        for name, id in BuiltinIcons do
            CachedIconMap[name] = id
        end

        if type(Env.InjectIcons) == "table" then
            for name, id in Env.InjectIcons do
                CachedIconMap[name] = id
            end
        end

        local Loader = loadstring or load
        if type(Loader) == "function" and type(readfile) == "function" and type(isfile) == "function" then
            for _, path in {"icons.lua", ".\\icons.lua"} do
                if isfile(path) then
                    local success, result = pcall(function()
                        return Loader(readfile(path))()
                    end)

                    if success and type(result) == "table" then
                        for name, id in result do
                            CachedIconMap[name] = id
                        end

                        break
                    end
                end
            end
        end

        return CachedIconMap
    end
