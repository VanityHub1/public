            function Window.UpdateBottomBarLayout()
                local BottomBarX = Objects.BottomBar.AbsolutePosition.X
                local LeftEdge = (Objects.BottomLeft.AbsolutePosition.X - BottomBarX) + Objects.BottomLeft.AbsoluteSize.X + 12
                local RightEdge = (Objects.BottomRight.AbsolutePosition.X - BottomBarX) - 12
                local Width = math.max(RightEdge - LeftEdge, 0)

                Objects.SubTabArea.Position = UDim2.new(0, LeftEdge, 0, 1)
                Objects.SubTabArea.Size = UDim2.new(0, Width, 1, -1)
            end

            function Window.ResetSubTabScroll()
                Objects.SubTabArea.CanvasPosition = Vector2.new()
            end

            function Window.ScrollSubTabIntoView(button)
                if not button or not button.Visible then
                    return
                end

                local AreaLeft = Objects.SubTabArea.AbsolutePosition.X
                local AreaRight = AreaLeft + Objects.SubTabArea.AbsoluteSize.X
                local ButtonLeft = button.AbsolutePosition.X
                local ButtonRight = ButtonLeft + button.AbsoluteSize.X
                local CanvasX = Objects.SubTabArea.CanvasPosition.X

                if ButtonLeft < AreaLeft then
                    CanvasX = math.max(0, CanvasX - (AreaLeft - ButtonLeft) - 6)
                elseif ButtonRight > AreaRight then
                    CanvasX = CanvasX + (ButtonRight - AreaRight) + 6
                end

                Objects.SubTabArea.CanvasPosition = Vector2.new(CanvasX, 0)
            end

