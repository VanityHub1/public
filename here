                end
            end))

            Utility.Signal(UserInputService.InputChanged:Connect(function(input)
                if Library.IsMoveInput(input) and Slider.Sliding then
                    local Position = Library.GetInputPosition(input)
                    Slider.Set( ((cfg.max - cfg.min) * ((Position.x - Objects.Outline.AbsolutePosition.x) / Objects.Outline.AbsoluteSize.x)) + cfg.min )
                end
            end))

