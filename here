                local ViewportSize = Camera.ViewportSize
                Window.IsMobile = (Window.MobileEnabled and UserInputService.TouchEnabled and ViewportSize.X <= 900) or Window.ForceMobile

                local OutlineWidth = cfg.size.X.Offset
                local OutlineHeight = cfg.size.Y.Offset

                if Window.IsMobile then
                    OutlineWidth = math.floor(math.clamp(ViewportSize.X - 12, 320, ViewportSize.X))
