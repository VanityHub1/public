                }, true)

                Library.ChangeObjectTheme(Objects.Value, {
                    TextColor3 = value > cfg.min and "Text" or "Dark Text"
                }, true)

                cfg.callback(Slider.Value)

                Library.Flags[cfg.flag] = Slider.Value
