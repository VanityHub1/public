                    Objects.TabScroll.Size = UDim2.new(1, -desktopTitleWidth - 8, 1, 0)
                    Objects.TabScroll.ScrollBarThickness = 0
                    Objects.SubTabArea.ScrollBarThickness = 0
                    Objects.BottomLeft.Position = UDim2.new(0, 10, 0, 1)
                    Objects.BottomRight.Position = UDim2.new(1, -10, 0, 1)
